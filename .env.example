# Signal Dispatch -- Environment Variables
# Copy this file to .env and fill in your values.

# ---------------------------------------------------------------------------
# Kalshi prediction markets (RSA-PSS auth)
# ---------------------------------------------------------------------------
KALSHI_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=

# ---------------------------------------------------------------------------
# FRED (Federal Reserve Economic Data)
# ---------------------------------------------------------------------------
FRED_API_KEY=

# ---------------------------------------------------------------------------
# EIA (Energy Information Administration)
# ---------------------------------------------------------------------------
EIA_API_KEY=

# ---------------------------------------------------------------------------
# AGSI (Aggregated Gas Storage Inventory)
# ---------------------------------------------------------------------------
AGSI_API_KEY=

# ---------------------------------------------------------------------------
# Cloudflare Radar (internet traffic monitoring)
# ---------------------------------------------------------------------------
CLOUDFLARE_RADAR_TOKEN=

# ---------------------------------------------------------------------------
# NASA FIRMS / VIIRS (fire hotspot detection)
# ---------------------------------------------------------------------------
NASA_FIRMS_MAP_KEY=

# ---------------------------------------------------------------------------
# Comtrade (UN trade statistics)
# ---------------------------------------------------------------------------
COMTRADE_API_KEY=

# ---------------------------------------------------------------------------
# OSINT adapters
# ---------------------------------------------------------------------------
CONGRESS_API_KEY=
FEC_API_KEY=

# ---------------------------------------------------------------------------
# ACLED (Armed Conflict Location & Event Data -- Oryx/conflict monitoring)
# ---------------------------------------------------------------------------
ACLED_ACCESS_TOKEN=
ACLED_REFRESH_TOKEN=
